# OpenAI — Realtime conversation + embeddings for RAG (required for voice)
OPENAI_API_KEY=

# ElevenLabs — Jude's spoken voice (required for voice replies)
ELEVENLABS_API_KEY=

# Good mode: Southern charm older lady (Jude Good — Southern Matriarch)
ELEVENLABS_VOICE_ID_GOOD=NsgfkY3cyxRG0efoRKYW
# ELEVENLABS_MODEL_GOOD=eleven_turbo_v2_5

# Evil mode: devilish robotic delivery, still kind (Jude Evil — Devilish Robot)
ELEVENLABS_VOICE_ID_EVIL=jEPqu2Z6cBH4GJyan8ZY
# ELEVENLABS_MODEL_EVIL=eleven_turbo_v2_5

# Fallback if GOOD/EVIL not set
ELEVENLABS_VOICE_ID=

# Admin training panel (optional — default 9/9 in dev)
# JUDE_ADMIN_USER=9
# JUDE_ADMIN_PASS=9
# JUDE_SESSION_SECRET=
# JUDE_TOKEN_ENCRYPTION_KEY=

# Google OAuth — Gmail connection (required for real Gmail sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3002/api/integrations/gmail/callback

# Local dev: npm run dev:demo → http://localhost:3002
# Copy this file to .env.local and add OPENAI_API_KEY + ELEVENLABS_API_KEY.
# Do not use `vercel env pull` for .env.local — it injects VERCEL=1 and empty keys.
